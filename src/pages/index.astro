---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import EcoPackages from '../components/EcoPackages';
import TreeTracker from '../components/TreeTracker';
---

<Layout title="NusaTree - Wisata Konservasi Hutan">
  <main class="container">
    <header class="header-section text-center">
      <h1 class="title-main">Tanam Pohonmu, <span class="title-highlight">Jejak Kebaikanmu</span></h1>
      <p class="subtitle">Pilih paket ekowisata edukasi kami, rasakan pengalaman menanam pohon dengan tangan Anda sendiri, dan pantau pertumbuhannya secara real-time.</p>
    </header>

    <section>
      <h2 style="font-size: 2rem; margin-bottom: 20px;">Mulai Petualangan Alam Anda</h2>
      <EcoPackages client:load /> 
    </section>

    <section id="tracker" class="tracker-box">
      <div class="text-center">
        <h2 style="font-size: 2rem; margin-bottom: 10px;">Transparansi yang Nyata</h2>
        <p class="subtitle" style="margin-bottom: 30px;">Masukkan Token ID Anda untuk memantau rekam jejak pohon yang telah ditanam.</p>
      </div>
      <TreeTracker client:load />
    </section>
  </main>
</Layout>